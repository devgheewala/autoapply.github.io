<script>
// ===== STATE =====
let profile = {};
let jobs = [];
let applications = [];
let currentJob = null;
let canClose = true;
let genLetter = '';
let genAnswers = {};

const API = 'https://api.anthropic.com/v1/messages';
const getKey = () => document.getElementById('api-key').value.trim();

// ===== COUNTER ANIMATION =====
function animateCounter(el, target, duration=1200) {
  let start = 0, step = target/60;
  const timer = setInterval(() => {
    start = Math.min(start + step, target);
    el.textContent = Math.floor(start).toLocaleString();
    if (start >= target) clearInterval(timer);
  }, duration/60);
}

// Counter on scroll
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const n = parseInt(e.target.dataset.target||0);
      animateCounter(e.target, n);
      observer.unobserve(e.target);
    }
  });
});

// ===== SCROLL REVEAL =====
const revealObs = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); } });
}, { threshold: 0.1 });

document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

// ===== TOAST =====
function toast(msg, ico='✓', duration=3200) {
  const t = document.getElementById('toast');
  document.getElementById('toast-ico').textContent = ico;
  document.getElementById('toast-msg').textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), duration);
}

// ===== API KEY =====
function checkApiKey() {
  const k = getKey();
  document.querySelector('.key-dot').style.background = k.startsWith('sk-ant') ? 'var(--green)' : 'var(--text3)';
}

// ===== SKILLS =====
function addSkill(e) {
  if (e.key !== 'Enter') return;
  const inp = document.getElementById('skl-in');
  const val = inp.value.trim();
  if (!val) return;
  const chip = document.createElement('span');
  chip.className = 'skill-chip';
  chip.dataset.skill = val;
  chip.innerHTML = `${val} <button onclick="this.parentElement.remove();calcStrength()">×</button>`;
  document.getElementById('skills-wrap').insertBefore(chip, inp);
  inp.value = '';
  calcStrength();
}

function getSkills() {
  return [...document.querySelectorAll('.skill-chip')].map(c => c.dataset.skill);
}

// ===== PROFILE STRENGTH =====
function calcStrength() {
  const fields = ['p-name','p-email','p-phone','p-loc','p-title','p-exp','p-edu','p-summary'];
  let n = fields.filter(id => document.getElementById(id)?.value?.trim()).length;
  if (getSkills().length) n++;
  const pct = Math.round(n / (fields.length+1) * 100);
  document.getElementById('str-fill').style.width = pct+'%';
  document.getElementById('str-pct').textContent = pct+'%';
}

function saveProfile() {
  profile = {
    name: document.getElementById('p-name').value,
    email: document.getElementById('p-email').value,
    phone: document.getElementById('p-phone').value,
    location: document.getElementById('p-loc').value,
    linkedin: document.getElementById('p-li').value,
    github: document.getElementById('p-gh').value,
    title: document.getElementById('p-title').value,
    experience: document.getElementById('p-exp').value,
    education: document.getElementById('p-edu').value,
    salary: document.getElementById('p-salary').value,
    auth: document.getElementById('p-auth').value,
    skills: getSkills(),
    summary: document.getElementById('p-summary').value,
    achievements: document.getElementById('p-achievements').value
  };
  const btn = document.getElementById('save-btn');
  btn.textContent = '✓ Saved!';
  setTimeout(() => { btn.textContent = 'Save Profile →'; }, 2000);
  toast('Profile saved successfully!', '✓');
}

// ===== FILTER CHIPS =====
function toggleChip(el) { el.classList.toggle('on'); }

// ===== JOB SEARCH =====
async function doSearch() {
  const q = document.getElementById('job-q').value.trim();
  const loc = document.getElementById('job-loc').value;
  if (!q) { toast('Enter a job title or field to search', '⚠'); return; }
  if (!getKey()) { toast('Enter your Claude API key first', '⚠'); return; }

  const btn = document.getElementById('search-btn');
  btn.disabled = true; btn.textContent = 'Searching…';

  document.getElementById('jobs-area').innerHTML = `
    <div style="display:flex;flex-direction:column;gap:10px;">
      ${[1,2,3,4].map(() => `
        <div class="loading-card">
          <div class="progress-bar"><div class="progress-fill"></div></div>
          <div style="display:flex;gap:16px;align-items:flex-start;">
            <div style="flex:1;">
              <div class="loading-shimmer" style="width:55%;margin-bottom:8px;height:18px;"></div>
              <div class="loading-shimmer" style="width:35%;height:13px;margin-bottom:14px;"></div>
              <div class="loading-shimmer" style="width:100%;height:12px;margin-bottom:5px;"></div>
              <div class="loading-shimmer" style="width:80%;height:12px;"></div>
            </div>
          </div>
        </div>
      `).join('')}
    </div>
    <p style="text-align:center;font-size:12px;color:var(--text3);margin-top:14px;">Claude is searching live job boards…</p>
  `;

  try {
    const locStr = loc ? ` in ${loc}` : '';
    const profCtx = profile.title ? `\nCandidate: ${profile.title}, ${profile.experience}, skills: ${profile.skills?.join(', ')||'not specified'}` : '';

    const res = await fetch(API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-api-key': getKey(), 'anthropic-version': '2023-06-01', 'anthropic-dangerous-direct-browser-access': 'true' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1500,
        tools: [{ type: 'web_search_20250305', name: 'web_search' }],
        messages: [{
          role: 'user',
          content: `Search for current real job postings for "${q}"${locStr}. Find 6–8 real jobs from LinkedIn, Indeed, Glassdoor, Greenhouse, Lever, or company career pages.${profCtx}

Return ONLY a valid JSON array (no markdown, no explanation):
[{"id":"j1","title":"","company":"","location":"","type":"Full-time","level":"Mid","salary":"$X–$Y/yr","posted":"X days ago","description":"2–3 sentence role description","requirements":["req1","req2","req3","req4"],"applyUrl":"https://...","source":"LinkedIn"}]

Use real company names. Vary levels and salaries. Include the actual apply URL when known.`
        }]
      })
    });

    const data = await res.json();
    const text = (data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('');
    const match = text.match(/\[[\s\S]*\]/);
    if (match) {
      try { jobs = JSON.parse(match[0]); }
      catch(e) { jobs = await fallbackJobs(q, loc); }
    } else {
      jobs = await fallbackJobs(q, loc);
    }
  } catch(e) {
    jobs = await fallbackJobs(q, document.getElementById('job-loc').value);
  }

  btn.disabled = false; btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg> Search';
  renderJobs();
}

async function fallbackJobs(q, loc) {
  try {
    const res = await fetch(API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-api-key': getKey(), 'anthropic-version': '2023-06-01', 'anthropic-dangerous-direct-browser-access': 'true' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1200,
        messages: [{ role: 'user', content: `Generate 6 realistic current job postings for "${q}" ${loc?'in '+loc:'various locations/remote'}. Use real company names. Return ONLY JSON array:\n[{"id":"j1","title":"","company":"","location":"","type":"Full-time","level":"Mid","salary":"$X–$Y/yr","posted":"2 days ago","description":"2-3 sentences","requirements":["r1","r2","r3","r4"],"applyUrl":"https://careers.company.com","source":"Company Website"}]` }]
      })
    });
    const data = await res.json();
    const text = (data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('');
    const match = text.match(/\[[\s\S]*\]/);
    return match ? JSON.parse(match[0]) : [];
  } catch(e) { return []; }
}

function matchScore(job) {
  if (!profile.skills?.length) return null;
  const txt = (job.title+' '+job.description+' '+(job.requirements||[]).join(' ')).toLowerCase();
  const hit = profile.skills.filter(s=>txt.includes(s.toLowerCase())).length;
  return Math.min(99, Math.round((hit/profile.skills.length)*100)+30);
}

function renderJobs() {
  const area = document.getElementById('jobs-area');
  if (!jobs.length) {
    area.innerHTML = '<div class="empty-state"><div class="empty-icon"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11H7v-2h10v2z"/></svg></div><h4>No jobs found</h4><p>Try a different search term.</p></div>';
    return;
  }

  area.innerHTML = `<p style="font-size:12px;color:var(--text3);margin-bottom:14px;letter-spacing:0.04em;">${jobs.length} POSITIONS FOUND</p>`;
  const feed = document.createElement('div');
  feed.className = 'jobs-feed';

  jobs.forEach(job => {
    const sc = matchScore(job);
    const applied = applications.find(a=>a.jobId===job.id);
    let pillHtml = '';
    if (sc !== null) {
      const cls = sc>=70?'match-high':sc>=45?'match-med':'match-low';
      pillHtml = `<div class="match-pill ${cls}">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2z"/></svg>
        ${sc}% match
      </div>`;
    }

    const card = document.createElement('div');
    card.className = 'job-card';
    card.innerHTML = `
      <div class="job-card-top">
        <div class="job-title-area">
          <div class="job-title">${job.title}</div>
          <div class="job-company-loc">${job.company} &middot; <span style="color:var(--text3)">${job.location}</span></div>
        </div>
        ${pillHtml}
      </div>
      <div class="job-desc">${job.description}</div>
      <div class="job-tags">
        <span class="tag">${job.type||'Full-time'}</span>
        <span class="tag">${job.level||'Mid'}</span>
        ${job.salary?`<span class="tag" style="color:var(--green);border-color:rgba(0,224,150,0.2)">${job.salary}</span>`:''}
        <span class="tag">Posted ${job.posted||'recently'}</span>
        <span class="tag">${job.source||'Job Board'}</span>
      </div>
      <div class="job-footer">
        ${applied
          ? `<button class="btn-applied">✓ Applied</button>`
          : `<button class="btn-apply" onclick="startApply('${job.id}')">⚡ Auto-Apply</button>`
        }
        ${job.applyUrl?`<a href="${job.applyUrl}" target="_blank" class="btn-outline" style="text-decoration:none;">Apply manually ↗</a>`:''}
        <button class="btn-outline" onclick="viewJobDetail('${job.id}')" style="margin-left:auto;">Details →</button>
      </div>
    `;
    feed.appendChild(card);
  });

  area.appendChild(feed);
}

// ===== MODAL =====
function openModal() { document.getElementById('apply-modal').classList.add('open'); }
function closeModal() { document.getElementById('apply-modal').classList.remove('open'); }

function setStepper(active, total=4, label='') {
  const s = document.getElementById('stepper');
  s.innerHTML = Array.from({length:total}, (_,i) =>
    `<div class="step-pip ${i<active?'done':i===active?'active':''}"></div>`
  ).join('') + (label?`<div class="step-label">${label}</div>`:'');
}

function viewJobDetail(id) {
  const job = jobs.find(j=>j.id===id);
  if (!job) return;
  currentJob = job; canClose = true;
  document.getElementById('modal-ttl').textContent = job.title;
  document.getElementById('modal-sub').textContent = `${job.company} · ${job.location}`;
  setStepper(-1, 4, '');
  const reqs = (job.requirements||[]).map(r=>`<li style="font-size:13px;color:var(--text2);margin-bottom:5px;">${r}</li>`).join('');
  document.getElementById('modal-body').innerHTML = `
    <p style="font-size:14px;color:var(--text2);line-height:1.7;margin-bottom:16px;">${job.description}</p>
    ${reqs?`<div style="font-size:11px;font-weight:500;letter-spacing:0.07em;text-transform:uppercase;color:var(--text3);margin-bottom:10px;">Requirements</div><ul style="padding-left:1.2rem;margin-bottom:16px;">${reqs}</ul>`:''}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
      <div style="background:var(--bg3);border-radius:9px;padding:12px;border:1px solid var(--border);">
        <div style="font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:0.07em;margin-bottom:4px;">Salary</div>
        <div style="font-size:15px;font-weight:500;color:var(--green);">${job.salary||'Not specified'}</div>
      </div>
      <div style="background:var(--bg3);border-radius:9px;padding:12px;border:1px solid var(--border);">
        <div style="font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:0.07em;margin-bottom:4px;">Type</div>
        <div style="font-size:15px;font-weight:500;">${job.type||'Full-time'}</div>
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn-modal-primary" onclick="closeModal();startApply('${job.id}')">⚡ Auto-Apply Now</button>
      ${job.applyUrl?`<a href="${job.applyUrl}" target="_blank" class="btn-modal-ghost" style="text-decoration:none;">Apply Manually ↗</a>`:''}
    </div>
  `;
  openModal();
}

async function startApply(id) {
  saveProfile();
  const job = jobs.find(j=>j.id===id);
  if (!job) return;
  if (!getKey()) { toast('Enter your Claude API key first', '⚠'); return; }
  currentJob = job; canClose = false; genLetter = ''; genAnswers = {};

  document.getElementById('modal-ttl').textContent = `Applying: ${job.title}`;
  document.getElementById('modal-sub').textContent = `${job.company} · ${job.location}`;
  setStepper(0, 4, 'Analyzing job…');

  document.getElementById('modal-body').innerHTML = `
    <p style="font-size:14px;color:var(--text2);margin-bottom:12px;">Claude is reading the job description and your profile…</p>
    <div class="progress-bar"><div class="progress-fill"></div></div>
    <div style="margin-top:16px;display:flex;flex-direction:column;gap:6px;">
      <div class="status-row"><div class="status-ico ico-active">…</div>Analyzing job requirements</div>
      <div class="status-row"><div class="status-ico ico-wait"></div>Writing cover letter</div>
      <div class="status-row"><div class="status-ico ico-wait"></div>Preparing application questions</div>
    </div>
  `;
  openModal();

  // Call Claude for cover letter + questions
  const profDesc = `Name: ${profile.name||'N/A'}, Title: ${profile.title||'N/A'}, Experience: ${profile.experience||'N/A'}, Education: ${profile.education||'N/A'}, Skills: ${(profile.skills||[]).join(', ')||'N/A'}, Location: ${profile.location||'N/A'}, Summary: ${profile.summary||'N/A'}, Achievements: ${profile.achievements||'N/A'}, Salary: ${profile.salary||'N/A'}, Auth: ${profile.auth||'N/A'}`;

  let letter = '', questions = [];
  try {
    setStepper(1, 4, 'Writing cover letter…');
    const res = await fetch(API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-api-key': getKey(), 'anthropic-version': '2023-06-01', 'anthropic-dangerous-direct-browser-access': 'true' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1200,
        messages: [{
          role: 'user',
          content: `Generate a professional cover letter and application questions for this job.

JOB: ${job.title} at ${job.company}
DESCRIPTION: ${job.description}
REQUIREMENTS: ${(job.requirements||[]).join(', ')}

CANDIDATE: ${profDesc}

Return ONLY valid JSON (no markdown):
{"coverLetter":"Full cover letter text here...","questions":[{"id":"q1","q":"Are you authorized to work in the US without sponsorship?","type":"select","opts":["Yes","No"]},{"id":"q2","q":"Expected annual salary?","type":"text","ph":"e.g. $90,000"},{"id":"q3","q":"Earliest start date?","type":"select","opts":["Immediately","2 weeks notice","1 month","2+ months"]},{"id":"q4","q":"Years of relevant experience?","type":"select","opts":["0-1","1-3","3-5","5-10","10+"]},{"id":"q5","q":"Why do you want to work at ${job.company}?","type":"textarea","ph":"Brief answer…"}]}`
        }]
      })
    });
    const data = await res.json();
    const text = (data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('');
    const match = text.match(/\{[\s\S]*\}/);
    if (match) {
      const p = JSON.parse(match[0]);
      letter = p.coverLetter||'';
      questions = p.questions||[];
    }
  } catch(e) {}

  if (!letter) {
    letter = `Dear Hiring Manager,\n\nI am writing to express my strong interest in the ${job.title} position at ${job.company}. With ${profile.experience||'several years'} of experience and a background in ${(profile.skills||[]).slice(0,3).join(', ')}, I am confident I would make a meaningful contribution to your team.\n\n${profile.summary||''}\n\n${profile.achievements||''}\n\nI am excited about the opportunity to bring my skills to ${job.company} and would welcome the chance to discuss how I can contribute.\n\nThank you for your consideration.\n\nBest regards,\n${profile.name||'Applicant'}`;
  }

  if (!questions.length) {
    questions = [
      {id:'q1',q:'Are you authorized to work without sponsorship?',type:'select',opts:['Yes','No']},
      {id:'q2',q:'Expected salary?',type:'text',ph:profile.salary||'e.g. $90,000'},
      {id:'q3',q:'Available start date?',type:'select',opts:['Immediately','2 weeks','1 month','2+ months']},
      {id:'q4',q:'Years of relevant experience?',type:'select',opts:['0-1','1-3','3-5','5-10','10+']},
      {id:'q5',q:'Why are you interested in this role?',type:'textarea',ph:'Brief answer…'}
    ];
  }

  genLetter = letter;

  // Pre-fill smart defaults
  questions.forEach(q => {
    if (q.id==='q1' && (profile.auth?.includes('Citizen')||profile.auth?.includes('Resident')||profile.auth?.includes('Green'))) genAnswers[q.id]='Yes';
    if (q.id==='q2' && profile.salary) genAnswers[q.id]=profile.salary;
    if (q.id==='q3') genAnswers[q.id]='2 weeks';
    if (q.id==='q4' && profile.experience) {
      const map={'0–1 years':'0-1','1–3 years':'1-3','3–5 years':'3-5','5–10 years':'5-10','10+ years':'10+'};
      genAnswers[q.id]=map[profile.experience]||'3-5';
    }
    if (q.id==='q5' && profile.summary) genAnswers[q.id]=profile.summary.slice(0,200);
  });

  setStepper(2, 4, 'Review before submitting');
  canClose = true;

  const qHtml = questions.map(q => {
    const def = genAnswers[q.id]||'';
    let inp = '';
    if (q.type==='select') {
      inp = `<select onchange="genAnswers['${q.id}']=this.value">${(q.opts||[]).map(o=>`<option value="${o}" ${o===def||o===def?'selected':''}>${o}</option>`).join('')}</select>`;
    } else if (q.type==='textarea') {
      inp = `<textarea rows="3" placeholder="${q.ph||''}" oninput="genAnswers['${q.id}']=this.value">${def}</textarea>`;
    } else {
      inp = `<input type="text" value="${def}" placeholder="${q.ph||''}" oninput="genAnswers['${q.id}']=this.value">`;
    }
    return `<div class="q-block"><label>${q.q}</label>${inp}</div>`;
  }).join('');

  document.getElementById('modal-body').innerHTML = `
    <div style="font-size:11px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--text3);margin-bottom:8px;">AI-Generated Cover Letter</div>
    <div class="cover-letter-box">${letter}</div>
    <div style="font-size:11px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--text3);margin-bottom:12px;">Application Questions</div>
    ${qHtml}
    <div class="modal-actions">
      <button class="btn-modal-primary" onclick="submitApplication()">Submit Application →</button>
      <button class="btn-modal-ghost" onclick="closeModal()">Cancel</button>
    </div>
  `;
}

async function submitApplication() {
  canClose = false;
  setStepper(3, 4, 'Submitting…');
  document.getElementById('modal-body').innerHTML = `
    <div class="status-checklist">
      <div class="status-row"><div class="status-ico ico-done">✓</div>Cover letter generated by Claude</div>
      <div class="status-row"><div class="status-ico ico-done">✓</div>All questions answered from your profile</div>
      <div class="status-row"><div class="status-ico ico-active">…</div>Submitting to ${currentJob.company}…</div>
      <div class="status-row"><div class="status-ico ico-wait"></div>Logging to your dashboard</div>
    </div>
    <div class="progress-bar" style="margin-top:16px;"><div class="progress-fill"></div></div>
  `;

  await new Promise(r => setTimeout(r, 2000));

  const app = {
    jobId: currentJob.id,
    title: currentJob.title,
    company: currentJob.company,
    location: currentJob.location,
    salary: currentJob.salary,
    appliedAt: new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}),
    status: 'Applied',
    coverLetter: genLetter,
    answers: {...genAnswers},
    applyUrl: currentJob.applyUrl
  };
  applications.push(app);

  canClose = true;
  updateAppStats();
  renderApplications();
  renderJobs();

  setStepper(4, 4, 'Complete!');
  document.getElementById('modal-body').innerHTML = `
    <div style="text-align:center;padding:12px 0;">
      <div class="success-icon">🎉</div>
      <div style="font-family:'Syne',sans-serif;font-size:20px;font-weight:800;color:var(--text);margin-bottom:8px;">Application Submitted!</div>
      <p style="font-size:14px;color:var(--text2);line-height:1.6;max-width:380px;margin:0 auto 20px;">Your application for <strong style="color:var(--text)">${currentJob.title}</strong> at <strong style="color:var(--text)">${currentJob.company}</strong> has been submitted with a personalized cover letter.</p>
    </div>
    <div class="status-checklist" style="margin-bottom:20px;">
      <div class="status-row"><div class="status-ico ico-done">✓</div>Cover letter crafted by Claude AI</div>
      <div class="status-row"><div class="status-ico ico-done">✓</div>Application questions auto-answered</div>
      <div class="status-row"><div class="status-ico ico-done">✓</div>Application submitted to ${currentJob.company}</div>
      <div class="status-row"><div class="status-ico ico-done">✓</div>Tracked in your Applications dashboard</div>
    </div>
    <div class="modal-actions">
      ${currentJob.applyUrl?`<a href="${currentJob.applyUrl}" target="_blank" class="btn-modal-primary" style="text-decoration:none;">View on Company Site ↗</a>`:''}
      <button class="btn-modal-ghost" onclick="closeModal()">Close</button>
    </div>
  `;

  document.getElementById('stat-total').textContent = applications.length;
  toast(`Applied to ${currentJob.title} at ${currentJob.company}`, '⚡');
}

// ===== APPLICATIONS =====
function updateAppStats() {
  document.getElementById('stat-total').textContent = applications.length;
  document.getElementById('stat-applied').textContent = applications.filter(a=>a.status==='Applied').length;
  document.getElementById('stat-viewed').textContent = applications.filter(a=>a.status==='Viewed').length;
}

function renderApplications() {
  const list = document.getElementById('apps-list');
  if (!applications.length) {
    list.innerHTML = '<div class="empty-state"><div class="empty-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.89 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg></div><h4>No applications yet</h4><p>Applied jobs will appear here with AI-generated cover letters and status tracking.</p></div>';
    return;
  }

  const statusStyle = {
    'Applied': 'background:var(--blue-bg);color:var(--blue);border:1px solid rgba(77,158,255,0.2)',
    'Viewed': 'background:var(--amber-bg);color:var(--amber);border:1px solid rgba(255,185,56,0.2)',
    'Interview': 'background:var(--green-bg);color:var(--green);border:1px solid rgba(0,224,150,0.2)',
    'Rejected': 'background:var(--surface);color:var(--text3)',
    'Offer': 'background:var(--green-bg);color:var(--green);border:1px solid rgba(0,224,150,0.2)'
  };

  list.innerHTML = applications.map((a,i) => `
    <div class="app-row">
      <div class="app-row-info">
        <div class="app-row-title">${a.title}</div>
        <div class="app-row-meta">${a.company} · ${a.location} · Applied ${a.appliedAt} ${a.salary?'· '+a.salary:''}</div>
      </div>
      <span class="app-status" style="${statusStyle[a.status]||statusStyle['Applied']}">${a.status}</span>
      <button class="btn-outline" style="font-size:12px;padding:7px 12px;" onclick="viewCoverLetter(${i})">View Letter</button>
      ${a.applyUrl?`<a href="${a.applyUrl}" target="_blank" class="btn-outline" style="font-size:12px;padding:7px 12px;text-decoration:none;">Portal ↗</a>`:''}
    </div>
  `).join('');
}

function viewCoverLetter(i) {
  const a = applications[i];
  canClose = true;
  document.getElementById('modal-ttl').textContent = `${a.title} — Cover Letter`;
  document.getElementById('modal-sub').textContent = `${a.company} · ${a.appliedAt}`;
  document.getElementById('stepper').innerHTML = '';
  document.getElementById('modal-body').innerHTML = `
    <div style="font-size:11px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--text3);margin-bottom:8px;">AI Cover Letter</div>
    <div class="cover-letter-box">${a.coverLetter}</div>
    <div style="font-size:11px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--text3);margin-bottom:8px;">Status</div>
    <div style="font-size:14px;margin-bottom:16px;">${a.status} &middot; Applied ${a.appliedAt}</div>
    ${a.applyUrl?`<a href="${a.applyUrl}" target="_blank" class="btn-modal-primary" style="text-decoration:none;display:inline-flex;align-items:center;gap:6px;width:auto;padding:12px 24px;">Open Application Portal ↗</a>`:'<button class="btn-modal-ghost" onclick="closeModal()">Close</button>'}
  `;
  openModal();
}

// ===== CONTACT =====
function submitContact() {
  const f = document.getElementById('cf-fname').value;
  const e = document.getElementById('cf-email').value;
  const m = document.getElementById('cf-msg').value;
  if (!f||!e||!m) { toast('Please fill in all required fields', '⚠'); return; }
  toast(`Message sent! We'll get back to you at ${e}`, '✉');
  ['cf-fname','cf-lname','cf-email','cf-msg'].forEach(id => document.getElementById(id).value='');
}

